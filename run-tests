#!/usr/bin/env bash

set -euo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PIO="${PIO:-$HOME/.platformio/penv/bin/pio}"
ENVIRONMENT="${PLATFORMIO_ENV:-native}"

if [[ ! -x "$PIO" ]]; then
  if command -v pio >/dev/null 2>&1; then
    PIO="$(command -v pio)"
  else
    printf 'PlatformIO was not found at %s or on PATH.\n' "$PIO" >&2
    exit 1
  fi
fi

cd "$PROJECT_DIR"

printf 'Testing PlatformIO environment "%s"...\n' "$ENVIRONMENT"
"$PIO" test -e "$ENVIRONMENT"
